# ─────────────────────────────────────────────
# Vext CRM v2.1 — Variáveis de Ambiente
# Copie para .env e ajuste conforme necessário
# ─────────────────────────────────────────────

# ── Docker / PostgreSQL Local ─────────────────
# Usadas pelo docker-compose.yml e pelo DATABASE_URL
DOCKER_PG_USER="vext"
DOCKER_PG_PASSWORD="vext123"
DOCKER_PG_DB="vext_crm"
DOCKER_PG_PORT=5433

# ── pgAdmin (acessível em http://localhost:5050)
DOCKER_PGADMIN_PORT=5050
DOCKER_PGADMIN_EMAIL="admin@vext.com.br"
DOCKER_PGADMIN_PASSWORD="admin123"

# ── Database ──────────────────────────────────
# Para Docker local: usa as variáveis acima (porta 5433)
# Para produção: substitua pela connection string do Oracle Cloud
DATABASE_URL="postgresql://vext:vext123@localhost:5433/vext_crm?schema=public"

# ── JWT - Access Token (curto) ────────────────
JWT_SECRET="sua-chave-secreta-super-segura-com-32-caracteres-ou-mais"
JWT_EXPIRES_IN="15m"

# ── Refresh Token (longo) ─────────────────────
REFRESH_TOKEN_SECRET="outra-chave-secreta-diferente-tambem-com-32-caracteres"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── AI (opcional — deixe vazio para desabilitar)
GEMINI_API_KEY=""

# ── Seed ──────────────────────────────────────
ADMIN_SEED_PASSWORD="VextAdmin@2025!"
