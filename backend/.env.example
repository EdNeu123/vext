# ─────────────────────────────────────────────
# Vext CRM v2.1 — Variáveis de Ambiente
# Copie para .env e ajuste conforme necessário
# ─────────────────────────────────────────────

# ── Docker / PostgreSQL Local ─────────────────
# Usadas pelo docker-compose.yml e pelo DATABASE_URL
DOCKER_PG_USER=""
DOCKER_PG_PASSWORD=""
DOCKER_PG_DB=""
DOCKER_PG_PORT=

# ── pgAdmin
DOCKER_PGADMIN_PORT=
DOCKER_PGADMIN_EMAIL=""
DOCKER_PGADMIN_PASSWORD=""

# ── Database ──────────────────────────────────
# Para Docker local
# Para produção: substitua pela connection string do Oracle Cloud
DATABASE_URL=""

# ── JWT - Access Token ────────────────
JWT_SECRET=""
JWT_EXPIRES_IN=""

# ── Refresh Token ─────────────────────
REFRESH_TOKEN_SECRET=""
REFRESH_TOKEN_EXPIRES_IN=""

# ── App ───────────────────────────────────────
NODE_ENV=""
PORT=
FRONTEND_URL=""
CORS_ORIGIN=""

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=

# ── AI (opcional — deixe vazio para desabilitar)
GEMINI_API_KEY=""

# ── Seed ──────────────────────────────────────
ADMIN_SEED_PASSWORD=""
