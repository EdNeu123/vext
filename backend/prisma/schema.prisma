// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  openId        String    @unique @db.VarChar(64)
  name          String?   @db.Text
  email         String?   @db.VarChar(320)
  phone         String?   @db.VarChar(32)
  avatar        String?   @db.Text
  loginMethod   String?   @db.VarChar(64)
  role          Role      @default(user)
  permissions   String?   @db.Text
  salesGoal     Decimal?  @db.Decimal(15, 2)
  birthDate     DateTime? @db.Date
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSignedIn  DateTime  @default(now())

  invites       Invite[]  @relation("InvitedBy")
  contacts      Contact[]
  deals         Deal[]
  tasks         Task[]    @relation("AssignedTo")
  createdTasks  Task[]    @relation("CreatedBy")
  landingPages  LandingPage[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([openId])
  @@index([email])
  @@index([role])
  @@map("users")
}

enum Role {
  user
  admin
}

model Invite {
  id         Int          @id @default(autoincrement())
  email      String       @db.VarChar(320)
  role       Role         @default(user)
  token      String       @unique @db.VarChar(255)
  invitedBy  Int
  status     InviteStatus @default(pending)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())

  inviter User @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
  @@index([status])
  @@map("invites")
}

enum InviteStatus {
  pending
  accepted
  revoked
}

model Contact {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(255)
  email            String?   @db.VarChar(320)
  phone            String?   @db.VarChar(32)
  company          String?   @db.VarChar(255)
  position         String?   @db.VarChar(255)
  segment          String?   @db.VarChar(100)
  ltv              Decimal?  @default(0) @db.Decimal(15, 2)
  avgTicket        Decimal?  @default(0) @db.Decimal(15, 2)
  totalPurchases   Int?      @default(0)
  lastPurchaseDate DateTime?
  churnRisk        ChurnRisk @default(low)
  nps              Int?
  notes            String?   @db.Text
  ownerId          Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deals         Deal[]
  tasks         Task[]
  aiPredictions AiPrediction[]

  @@index([name])
  @@index([email])
  @@index([company])
  @@index([ownerId])
  @@index([churnRisk])
  @@map("contacts")
}

enum ChurnRisk {
  low
  medium
  high
}

model Deal {
  id                      Int       @id @default(autoincrement())
  title                   String    @db.VarChar(255)
  value                   Decimal   @db.Decimal(15, 2)
  stage                   DealStage @default(prospecting)
  probability             Int?      @default(0)
  contactId               Int
  productId               Int?
  ownerId                 Int
  budgetConfirmed         Boolean?  @default(false)
  decisionMakerIdentified Boolean?  @default(false)
  painPoints              String?   @db.Text
  competitors             String?   @db.Text
  timeline                String?   @db.VarChar(255)
  nextFollowUpDate        DateTime?
  notes                   String?   @db.Text
  lostReason              String?   @db.Text
  wonDate                 DateTime?
  lostDate                DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  contact Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks   Task[]
  tags    DealTag[]

  @@index([stage])
  @@index([contactId])
  @@index([ownerId])
  @@index([nextFollowUpDate])
  @@map("deals")
}

enum DealStage {
  prospecting
  qualification
  presentation
  negotiation
  won
  lost
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(15, 2)
  sku         String?  @db.VarChar(100)
  category    String?  @db.VarChar(100)
  isActive    Boolean? @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([sku])
  @@index([category])
  @@index([isActive])
  @@map("products")
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  type        TaskType   @default(other)
  status      TaskStatus @default(pending)
  priority    Priority   @default(medium)
  dueDate     DateTime
  completedAt DateTime?
  contactId   Int?
  dealId      Int?
  assignedTo  Int
  createdBy   Int
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedUser User     @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: Cascade)
  creator      User     @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([dueDate])
  @@index([assignedTo])
  @@index([type])
  @@map("tasks")
}

enum TaskType {
  call
  meeting
  email
  follow_up
  other
}

enum TaskStatus {
  pending
  completed
  cancelled
}

enum Priority {
  low
  medium
  high
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  color     String   @default("#3b82f6") @db.VarChar(7)
  createdAt DateTime @default(now())

  deals DealTag[]

  @@index([name])
  @@map("tags")
}

model DealTag {
  dealId Int
  tagId  Int

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
  @@map("deal_tags")
}

model LandingPage {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  content     String   @db.Text
  theme       String?  @default("default") @db.VarChar(50)
  isPublished Boolean? @default(false)
  views       Int?     @default(0)
  conversions Int?     @default(0)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([isPublished])
  @@index([createdBy])
  @@map("landing_pages")
}

model AuditLog {
  id         Int        @id @default(autoincrement())
  entityType EntityType
  entityId   Int
  action     String     @db.VarChar(255)
  userId     Int
  userName   String     @db.VarChar(255)
  changes    String?    @db.Text
  reason     String?    @db.Text
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum EntityType {
  deal
  contact
  product
  user
  invite
  task
  landing_page
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String           @db.VarChar(255)
  message   String           @db.Text
  type      NotificationType @default(info)
  isRead    Boolean?         @default(false)
  actionUrl String?          @db.VarChar(500)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  info
  success
  warning
  error
}

model AiPrediction {
  id             Int            @id @default(autoincrement())
  contactId      Int
  predictionType PredictionType
  score          Decimal        @db.Decimal(5, 2)
  reason         String?        @db.Text
  suggestedAction String?       @db.Text
  createdAt      DateTime       @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([predictionType])
  @@index([score])
  @@map("ai_predictions")
}

enum PredictionType {
  churn
  repurchase
  upsell
}
