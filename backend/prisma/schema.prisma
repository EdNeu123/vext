generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS & AUTHENTICATION
// ==========================================

enum UserRole {
  admin
  seller
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(320)
  password     String    @db.VarChar(255)
  name         String    @db.VarChar(255)
  phone        String?   @db.VarChar(32)
  avatar       String?   @db.Text
  role         UserRole  @default(seller)
  permissions  Json?     @default("[]")
  salesGoal    Decimal?  @db.Decimal(15, 2)
  birthDate    DateTime? @db.Date
  isActive     Boolean   @default(true)
  lastSignedIn DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts       Contact[]
  cards          Card[]
  tasks          Task[]
  landingPages   LandingPage[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  invitesSent    Invite[]        @relation("InvitedBy")
  refreshTokens  RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ==========================================
// REFRESH TOKENS
// ==========================================

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ==========================================
// INVITES
// ==========================================

enum InviteStatus {
  pending
  used
  expired
}

model Invite {
  id          Int          @id @default(autoincrement())
  token       String       @unique @db.VarChar(64)
  email       String       @db.VarChar(320)
  name        String       @db.VarChar(255)
  role        UserRole     @default(seller)
  permissions Json?        @default("[]")
  status      InviteStatus @default(pending)
  invitedBy   Int
  usedBy      Int?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime     @default(now())

  inviter User @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([status])
  @@map("invites")
}

// ==========================================
// CONTACTS
// ==========================================

enum ChurnRisk {
  low
  medium
  high
}

model Contact {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  email           String?   @db.VarChar(320)
  phone           String?   @db.VarChar(32)
  company         String?   @db.VarChar(255)
  position        String?   @db.VarChar(255)
  source          String?   @db.VarChar(100)
  notes           String?   @db.Text
  ltv             Decimal?  @default(0) @db.Decimal(15, 2)
  averageTicket   Decimal?  @default(0) @db.Decimal(15, 2)
  totalPurchases  Int       @default(0)
  lastPurchaseAt  DateTime?
  bestContactTime String?   @db.VarChar(50)
  churnRisk       ChurnRisk @default(low)
  npsScore        Int?
  ownerId         Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards Card[]
  tasks Task[]

  @@index([name])
  @@index([email])
  @@index([company])
  @@index([ownerId])
  @@index([churnRisk])
  @@map("contacts")
}

// ==========================================
// TAGS
// ==========================================

model Tag {
  id        Int      @id @default(autoincrement())
  label     String   @unique @db.VarChar(100)
  color     String   @default("#3b82f6") @db.VarChar(100)
  createdAt DateTime @default(now())

  cards CardTag[]

  @@map("tags")
}

// ==========================================
// PRODUCTS
// ==========================================

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  price       Decimal  @db.Decimal(15, 2)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards        Card[]
  landingPages LandingPage[]

  @@index([name])
  @@index([isActive])
  @@map("products")
}

// ==========================================
// DEALS (Pipeline)
// ==========================================

enum CardStage {
  prospecting
  qualification
  presentation
  negotiation
  won
  lost
}

model Card {
  id                      Int       @id @default(autoincrement())
  title                   String    @db.VarChar(255)
  value                   Decimal   @db.Decimal(15, 2)
  stage                   CardStage @default(prospecting)
  probability             Int       @default(10)
  contactId               Int
  ownerId                 Int
  productId               Int?
  budgetConfirmed         Boolean   @default(false)
  decisionMakerIdentified Boolean   @default(false)
  painPoints              String?   @db.Text
  competitors             String?   @db.Text
  timeline                String?   @db.VarChar(100)
  nextFollowUpDate        DateTime?
  notes                   String?   @db.Text
  closedAt                DateTime?
  lostReason              String?   @db.Text
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  contact Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  owner   User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  product Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  tags    CardTag[]
  tasks   Task[]

  @@index([stage])
  @@index([contactId])
  @@index([ownerId])
  @@index([nextFollowUpDate])
  @@map("cards")
}

model CardTag {
  cardId Int
  tagId  Int

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@map("card_tags")
}

// ==========================================
// TASKS
// ==========================================

enum TaskType {
  call
  meeting
  email
  follow_up
  other
}

enum TaskStatus {
  pending
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(255)
  description String?      @db.Text
  type        TaskType     @default(other)
  status      TaskStatus   @default(pending)
  priority    TaskPriority @default(medium)
  dueDate     DateTime
  completedAt DateTime?
  cardId      Int?
  contactId   Int?
  ownerId     Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  card   Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([dueDate])
  @@index([ownerId])
  @@map("tasks")
}

// ==========================================
// LANDING PAGES
// ==========================================

enum ThemeColor {
  indigo
  emerald
  rose
  amber
  blue
  purple
}

model LandingPage {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  headline    String     @db.VarChar(500)
  subheadline String?    @db.Text
  ctaText     String?    @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  themeColor  ThemeColor @default(indigo)
  productId   Int?
  views       Int        @default(0)
  conversions Int        @default(0)
  isActive    Boolean    @default(true)
  ownerId     Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([ownerId])
  @@map("landing_pages")
}

// ==========================================
// AUDIT LOG
// ==========================================

enum EntityType {
  card
  contact
  product
  user
  invite
  task
  landing_page
}

model AuditLog {
  id         Int        @id @default(autoincrement())
  entityType EntityType
  entityId   Int
  action     String     @db.VarChar(255)
  changes    Json?
  reason     String?    @db.Text
  userId     Int
  userName   String     @db.VarChar(255)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

enum NotificationType {
  info
  success
  warning
  error
  ai
}

model Notification {
  id        Int              @id @default(autoincrement())
  title     String           @db.VarChar(255)
  message   String?          @db.Text
  type      NotificationType @default(info)
  isRead    Boolean          @default(false)
  userId    Int
  link      String?          @db.VarChar(500)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ==========================================
// AI PREDICTIONS
// ==========================================

enum PredictionType {
  churn_risk
  repurchase
  deal_score
  best_contact_time
}

enum PredictionEntityType {
  contact
  card
}

model AiPrediction {
  id             Int                  @id @default(autoincrement())
  type           PredictionType
  entityType     PredictionEntityType
  entityId       Int
  score          Decimal?             @db.Decimal(5, 2)
  confidence     Decimal?             @db.Decimal(5, 2)
  factors        Json?
  recommendation String?              @db.Text
  createdAt      DateTime             @default(now())
  expiresAt      DateTime?

  @@index([entityType, entityId])
  @@index([type])
  @@map("ai_predictions")
}
