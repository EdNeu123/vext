# ============================================================
#  .env.hml — Variáveis de Ambiente — Homologação
#  Vext CRM v2.1.0
#  ⚠️  NÃO versionar este arquivo com valores reais
#      Copie para .env.hml e preencha com seus dados
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=vext_hml
POSTGRES_PASSWORD=vext_hml_secret_troque_em_prod
POSTGRES_DB=vextcrm_hml
POSTGRES_PORT=5433              # Porta exposta no host (evita conflito com 5432 local)

# ---------- Prisma (backend) ----------
DATABASE_URL="postgresql://vext_hml:vext_hml_secret_troque_em_prod@localhost:5433/vextcrm_hml?schema=public"

# ---------- pgAdmin (opcional) ----------
PGADMIN_EMAIL=admin@vextcrm.hml
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
